<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TeacherAssistant.Desktop.ViewModels"
             xmlns:whiteboard="clr-namespace:TeacherAssistant.Whiteboard.Views;assembly=TeacherAssistant.Whiteboard"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="TeacherAssistant.Desktop.Views.WhiteboardView"
             x:DataType="vm:WhiteboardViewModel"
             ClipToBounds="True"
             Background="Transparent">

    <whiteboard:WhiteboardCanvas x:Name="Canvas"
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Stretch" />
</UserControl>
